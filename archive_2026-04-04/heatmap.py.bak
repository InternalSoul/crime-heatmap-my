from __future__ import annotations

from pathlib import Path
import json

import pandas as pd


BASE_DIR = Path(__file__).resolve().parent
CSV_CANDIDATES = [BASE_DIR / "crime_district.csv", BASE_DIR / "crime_data.csv"]
OUTPUT_FILE = BASE_DIR / "crime_heatmap.html"


def load_data() -> pd.DataFrame:
    for csv_path in CSV_CANDIDATES:
        if csv_path.exists():
            return pd.read_csv(csv_path)
    raise FileNotFoundError(
        f"No crime CSV found. Looked for: {', '.join(str(p.name) for p in CSV_CANDIDATES)}"
    )


def load_coordinates() -> pd.DataFrame:
    coord_file = BASE_DIR / "district_coordinates.csv"
    if coord_file.exists():
        return pd.read_csv(coord_file)
    raise FileNotFoundError(f"Coordinates file not found at {coord_file}")


def build_heatmap_from_coordinates(df: pd.DataFrame, coords_df: pd.DataFrame) -> list[dict]:
    import random
    import numpy as np
    
    required_columns = {"state", "district", "category", "type", "date", "crimes"}
    if not required_columns.issubset(df.columns):
        raise ValueError("CSV must contain state/district/category/type/date/crimes columns.")

    working = df.dropna(subset=["state", "district", "category", "type", "date", "crimes"]).copy()
    working["year"] = pd.to_datetime(working["date"], errors="coerce").dt.year
    working = working.dropna(subset=["year"])

    aggregated = (
        working.groupby(["state", "district", "category", "type", "year"], as_index=False)["crimes"]
        .sum()
    )

    merged = aggregated.merge(coords_df, on=["state", "district"], how="left")

    heat_data: list[dict] = []
    successful = 0
    failed = 0
    
    # Grid size: approximately 0.02 degrees (~2km at equator) per grid cell
    # This creates a grid around each district center
    GRID_SIZE = 0.02
    POINTS_PER_CRIME = 0.15  # Spread larger crime counts into multiple points

    for _, row in merged.iterrows():
        if pd.isna(row.get("latitude")) or pd.isna(row.get("longitude")):
            failed += 1
            continue

        center_lat = float(row["latitude"])
        center_lon = float(row["longitude"])
        crimes = int(row["crimes"])
        
        # Create multiple points based on crime count for street-level distribution
        # Larger crime numbers get distributed across the grid
        num_points = max(1, int(np.ceil(crimes * POINTS_PER_CRIME)))
        
        for _ in range(num_points):
            # Generate random offset within grid
            lat_offset = random.uniform(-GRID_SIZE, GRID_SIZE)
            lon_offset = random.uniform(-GRID_SIZE, GRID_SIZE)
            
            point_lat = center_lat + lat_offset
            point_lon = center_lon + lon_offset
            
            # Distribute crime count across points
            point_crimes = crimes / num_points
            
            heat_data.append(
                {
                    "lat": point_lat,
                    "lon": point_lon,
                    "crimes": point_crimes,
                    "state": str(row["state"]),
                    "district": str(row["district"]),
                    "category": str(row["category"]),
                    "type": str(row["type"]),
                    "year": int(row["year"]),
                }
            )
            successful += 1

    print(f"📊 Summary: {successful} heat points generated from {aggregated.shape[0]} districts, {failed} not found")
    return heat_data


def write_html_map(heat_data: list[dict], output_file: Path) -> None:
    points_js = json.dumps(heat_data)

    states = sorted({p["state"] for p in heat_data if p.get("state") and p["state"] != "Malaysia"})
    districts_by_state: dict[str, list[str]] = {
        state: sorted({p["district"] for p in heat_data if p.get("state") == state and p.get("district")})
        for state in states
    }
    years = sorted({int(p["year"]) for p in heat_data if p.get("year") is not None})
    types = sorted({p["type"] for p in heat_data if p.get("type") and p["type"] != "all"})

    colors = {
        "murder": "#7b3294",
        "rape": "#1a9850",
        "causing_injury": "#fdae61",
        "robbery_gang_armed": "#d73027",
        "robbery_gang_unarmed": "#fc8d59",
        "robbery_solo_armed": "#fee08b",
        "robbery_solo_unarmed": "#91bfdb",
        "break_in": "#4575b4",
        "theft_other": "#66c2a5",
        "theft_vehicle_lorry": "#3288bd",
        "theft_vehicle_motorcar": "#5e4fa2",
        "theft_vehicle_motorcycle": "#e6f598",
    }

    html_content = """<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Crime Heatmap</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    html, body, #map { height: 100%; margin: 0; font-family: Arial, sans-serif; }
    .panel {
      position: absolute;
      z-index: 1000;
      background: rgba(255,255,255,0.96);
      padding: 12px;
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.18);
      overflow-y: auto;
      font-size: 13px;
    }
    .filters-panel { top: 16px; left: 16px; width: 360px; max-height: 62vh; }
    .stats-panel { top: 16px; right: 16px; width: 280px; max-height: 42vh; }
    .legend-panel { bottom: 16px; right: 16px; width: 280px; max-height: 32vh; }
    .data-toggle {
      position: absolute;
      left: 16px;
      bottom: 16px;
      z-index: 1000;
      border: none;
      border-radius: 8px;
      padding: 10px 12px;
      font-weight: 700;
      cursor: pointer;
      background: #2f7ed8;
      color: #fff;
      box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    }
    .data-drawer {
      position: absolute;
      z-index: 1200;
      left: 16px;
      right: 16px;
      bottom: 16px;
      max-height: 42vh;
      display: none;
    }
    .data-drawer.open { display: block; }

    h3 { margin: 0 0 10px 0; font-size: 16px; border-bottom: 2px solid #e0e0e0; padding-bottom: 8px; }
    .field { margin-bottom: 10px; }
    .label { display: block; margin-bottom: 6px; font-weight: 600; color: #444; }
    .field-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }
    .mini-btns { display: flex; gap: 6px; }
    .mini-btns button {
      border: 1px solid #d0d0d0;
      border-radius: 999px;
      background: #fff;
      padding: 2px 8px;
      font-size: 11px;
      cursor: pointer;
    }

    .checklist {
      border: 1px solid #d0d0d0;
      border-radius: 8px;
      background: #fff;
      padding: 6px;
      max-height: 96px;
      overflow-y: auto;
    }
    .check-item { display: flex; align-items: center; gap: 8px; margin: 4px 0; font-size: 12px; }
    .check-item input { margin: 0; }

    .buttons { display: flex; gap: 8px; margin-top: 10px; }
    .buttons button {
      flex: 1;
      border: none;
      border-radius: 8px;
      padding: 8px 10px;
      cursor: pointer;
      font-weight: 700;
      color: white;
    }
    .btn-clear { background: #d9534f; }
    .btn-reset { background: #5b9bd5; }

    .stat-row, .legend-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 7px 0; border-bottom: 1px solid #f0f0f0; }
    .stat-row:last-child, .legend-row:last-child { border-bottom: none; }
    .stat-name { flex: 1; color: #555; }
    .stat-value { font-weight: 700; color: #d32f2f; }
    .legend-item { display: flex; align-items: center; gap: 8px; }
    .legend-swatch { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }

    .data-summary { font-size: 12px; color: #444; margin-bottom: 8px; }
    .data-table-wrap { max-height: 22vh; overflow: auto; border: 1px solid #e6e6e6; border-radius: 8px; }
    table { border-collapse: collapse; width: 100%; font-size: 12px; background: #fff; }
    th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #f0f0f0; white-space: nowrap; }
    th { position: sticky; top: 0; background: #fafafa; z-index: 1; }
  </style>
</head>
<body>
  <div id="map"></div>

  <div class="panel filters-panel">
    <h3>Filters</h3>

    <div class="field">
      <div class="field-head">
        <span class="label">State</span>
        <div class="mini-btns"><button type="button" data-scope="state" data-act="all">All</button><button type="button" data-scope="state" data-act="none">None</button></div>
      </div>
      <div id="state-list" class="checklist"></div>
    </div>
    <div class="field">
      <div class="field-head">
        <span class="label">District</span>
        <div class="mini-btns"><button type="button" data-scope="district" data-act="all">All</button><button type="button" data-scope="district" data-act="none">None</button></div>
      </div>
      <div id="district-list" class="checklist"></div>
    </div>
    <div class="field">
      <div class="field-head">
        <span class="label">Year</span>
        <div class="mini-btns"><button type="button" data-scope="year" data-act="all">All</button><button type="button" data-scope="year" data-act="none">None</button></div>
      </div>
      <div id="year-list" class="checklist"></div>
    </div>
    <div class="field">
      <div class="field-head">
        <span class="label">Crime Type</span>
        <div class="mini-btns"><button type="button" data-scope="type" data-act="all">All</button><button type="button" data-scope="type" data-act="none">None</button></div>
      </div>
      <div id="type-list" class="checklist"></div>
    </div>

    <div class="buttons">
      <button class="btn-clear" id="clear-filters" type="button">Untick all</button>
      <button class="btn-reset" id="reset-filters" type="button">Reset</button>
    </div>
  </div>

  <button id="data-toggle" class="data-toggle" type="button">View Filtered Data</button>

  <div id="data-drawer" class="panel data-drawer">
    <div class="field-head"><h3 style="margin:0;border:0;padding:0;">Filtered Crime Data</h3><button id="data-close" type="button">Close</button></div>
    <div id="data-summary" class="data-summary"></div>
    <div class="data-table-wrap">
      <table>
        <thead>
          <tr><th>State</th><th>District</th><th>Year</th><th>Category</th><th>Type</th><th>Crimes</th></tr>
        </thead>
        <tbody id="data-rows"></tbody>
      </table>
    </div>
  </div>

  <div class="panel stats-panel">
    <h3 id="stats-title">Crime by State</h3>
    <div id="stats-container"></div>
  </div>

  <div class="panel legend-panel">
    <h3>Legend</h3>
    <div style="font-size:12px;color:#666;margin-bottom:8px;">Heat intensity increases with more incidents in the selected filters.</div>
    <div id="legend-items"></div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
  <script>
    const heatPoints = __POINTS__;
    const states = __STATES__;
    const districtsByState = __DISTRICTS_BY_STATE__;
    const years = __YEARS__;
    const types = __TYPES__;
    const colors = __COLORS__;

    const map = L.map('map').setView([3.14, 101.69], 7);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    const els = {
      state: document.getElementById('state-list'),
      district: document.getElementById('district-list'),
      year: document.getElementById('year-list'),
      type: document.getElementById('type-list'),
      statsTitle: document.getElementById('stats-title'),
      stats: document.getElementById('stats-container'),
      dataSummary: document.getElementById('data-summary'),
      dataRows: document.getElementById('data-rows')
    };

    const selected = {
      state: new Set(states),
      district: new Set(),
      year: new Set(years.map(String)),
      type: new Set()
    };

    let heatLayers = [];

    function toggleSet(setObj, value) {
      if (setObj.has(value)) setObj.delete(value);
      else setObj.add(value);
    }

    function renderChecklist(container, items, setObj, onChange) {
      container.innerHTML = items.map(v => `
        <label class="check-item">
          <input type="checkbox" value="${v}" ${setObj.has(String(v)) || setObj.has(v) ? 'checked' : ''}>
          <span>${v}</span>
        </label>
      `).join('');
      container.querySelectorAll('input[type="checkbox"]').forEach(input => {
        input.addEventListener('change', () => onChange(input.value));
      });
    }

    function activeStates() {
      return selected.state.size ? Array.from(selected.state) : states;
    }

    function availableDistricts() {
      const districtSet = new Set();
      activeStates().forEach(s => (districtsByState[s] || []).forEach(d => districtSet.add(d)));
      return Array.from(districtSet).sort();
    }

    function availableTypes() { return types; }

    function syncDynamicSelections() {
      const dOptions = new Set(availableDistricts());
      if (!selected.district.size) {
        selected.district = new Set(dOptions);
      } else {
        selected.district = new Set(Array.from(selected.district).filter(d => dOptions.has(d)));
        if (!selected.district.size) selected.district = new Set(dOptions);
      }

      const tOptions = new Set(availableTypes());
      if (!selected.type.size) {
        selected.type = new Set(tOptions);
      } else {
        selected.type = new Set(Array.from(selected.type).filter(t => tOptions.has(t)));
        if (!selected.type.size) selected.type = new Set(tOptions);
      }
    }

    function filteredPoints() {
      const stateAny = selected.state.size === 0;
      const districtAny = selected.district.size === 0;
      const yearAny = selected.year.size === 0;
      const typeAny = selected.type.size === 0;

      return heatPoints.filter(p => {
        const s = stateAny || selected.state.has(p.state);
        const d = districtAny || selected.district.has(p.district);
        const y = yearAny || selected.year.has(String(p.year));
        const t = typeAny || selected.type.has(p.type);
        return s && d && y && t;
      });
    }

    function getHeatStyle(pointCount, districtCount) {
      const districtFocused = districtCount === 1;
      let radius = districtFocused ? 74 : 40;
      let blur = districtFocused ? 54 : 30;
      const zoom = map.getZoom();

      if (zoom >= 10) {
        radius = Math.max(24, radius - 14);
        blur = Math.max(18, blur - 10);
      }
      if (zoom >= 13) {
        radius = Math.max(18, radius - 8);
        blur = Math.max(14, blur - 6);
      }
      if (pointCount < 30) {
        radius += 10;
        blur += 6;
      }
      return { radius, blur };
    }

    function renderStats(points) {
      const selectedTypes = selected.type.size ? Array.from(selected.type) : availableTypes();
      if (selectedTypes.length === 1) {
        const rawLabel = selectedTypes[0].replace(/_/g, ' ');
        const label = rawLabel.charAt(0).toUpperCase() + rawLabel.slice(1);
        els.statsTitle.textContent = `${label} by State`;
      } else if (selectedTypes.length > 1 && selectedTypes.length < availableTypes().length) {
        els.statsTitle.textContent = 'Selected Crimes by State';
      } else {
        els.statsTitle.textContent = 'Crime by State';
      }

      const stats = {};
      points.forEach(p => {
        stats[p.state] = (stats[p.state] || 0) + p.crimes;
      });

      els.stats.innerHTML = Object.entries(stats)
        .sort((a, b) => b[1] - a[1])
        .map(([state, crimes]) => `<div class="stat-row"><span class="stat-name">${state}</span><span class="stat-value">${Number(crimes).toLocaleString()}</span></div>`)
        .join('') || '<div style="color:#666;">No data for selected filters.</div>';
    }

    function renderDataTable(points) {
      const grouped = new Map();
      points.forEach(p => {
        const key = `${p.state}|${p.district}|${p.year}|${p.category}|${p.type}`;
        grouped.set(key, (grouped.get(key) || 0) + p.crimes);
      });

      const rows = Array.from(grouped.entries()).map(([k, crimes]) => {
        const [state, district, year, category, type] = k.split('|');
        return { state, district, year, category, type, crimes };
      }).sort((a, b) => b.crimes - a.crimes);

      const total = rows.reduce((s, r) => s + r.crimes, 0);
      els.dataSummary.textContent = `${rows.length} rows • Total crimes: ${Math.round(total).toLocaleString()}`;

      els.dataRows.innerHTML = rows.slice(0, 300).map(r => `
        <tr>
          <td>${r.state}</td>
          <td>${r.district}</td>
          <td>${r.year}</td>
          <td>${r.category}</td>
          <td>${r.type}</td>
          <td>${Math.round(r.crimes).toLocaleString()}</td>
        </tr>
      `).join('') || '<tr><td colspan="6" style="color:#666;">No data for selected filters.</td></tr>';
    }

    function renderLegend() {
      document.getElementById('legend-items').innerHTML = Object.keys(colors)
        .map(type => `<div class="legend-row"><span class="legend-item"><span class="legend-swatch" style="background:${colors[type]}"></span>${type}</span></div>`)
        .join('');
    }

    function renderHeatmap(shouldFit = false) {
      heatLayers.forEach(layer => map.removeLayer(layer));
      heatLayers = [];

      const points = filteredPoints();
      if (!points.length) {
        renderStats(points);
        renderDataTable(points);
        return;
      }

      const activeTypes = selected.type.size ? Array.from(selected.type) : Array.from(new Set(points.map(p => p.type)));
      const districtCount = selected.district.size;
      const style = getHeatStyle(points.length, districtCount);

      activeTypes.forEach(type => {
        const typePoints = points.filter(p => p.type === type);
        if (!typePoints.length) return;

        const maxCrimes = Math.max(...typePoints.map(p => p.crimes), 1);
        const layerData = typePoints.map(p => [p.lat, p.lon, Math.max(0.15, p.crimes / maxCrimes)]);
        const heatColor = colors[type] || '#d73027';

        const layer = L.heatLayer(layerData, {
          radius: style.radius,
          blur: style.blur,
          minOpacity: 0.5,
          maxZoom: 11,
          gradient: { 0.08: '#ffd6d6', 0.3: heatColor, 0.65: heatColor, 1.0: '#7a0000' }
        }).addTo(map);
        heatLayers.push(layer);
      });

      if (shouldFit) {
        const bounds = L.latLngBounds(points.map(p => [p.lat, p.lon]));
        map.fitBounds(bounds.pad(0.15));
      }

      renderStats(points);
      renderDataTable(points);
    }

    function renderAllControls() {
      renderChecklist(els.state, states, selected.state, value => {
        toggleSet(selected.state, value);
        syncDynamicSelections();
        renderAllControls();
        renderHeatmap(true);
      });

      const districts = availableDistricts();
      renderChecklist(els.district, districts, selected.district, value => {
        toggleSet(selected.district, value);
        renderAllControls();
        renderHeatmap(true);
      });

      renderChecklist(els.year, years.map(String), selected.year, value => {
        toggleSet(selected.year, value);
        renderAllControls();
        renderHeatmap(true);
      });

      const types = availableTypes();
      renderChecklist(els.type, types, selected.type, value => {
        toggleSet(selected.type, value);
        renderAllControls();
        renderHeatmap(true);
      });
    }

    function untickAll() {
      selected.state.clear();
      selected.district.clear();
      selected.year.clear();
      selected.type.clear();
      renderAllControls();
      renderHeatmap();
    }

    function resetFilters() {
      selected.state = new Set(states);
      selected.year = new Set(years.map(String));
      syncDynamicSelections();
      renderAllControls();
      renderHeatmap(true);
    }

    function setScopeSelection(scope, mode) {
      const options = {
        state: states,
        district: availableDistricts(),
        year: years.map(String),
        type: availableTypes(),
      };
      selected[scope] = mode === 'all' ? new Set(options[scope]) : new Set();
      if (scope === 'state') {
        syncDynamicSelections();
      }
      if (scope === 'district') {
        const valid = new Set(availableDistricts());
        selected.district = new Set(Array.from(selected.district).filter(d => valid.has(d)));
      }
      if (scope === 'type') {
        const validTypes = new Set(availableTypes());
        selected.type = new Set(Array.from(selected.type).filter(t => validTypes.has(t)));
      }
      renderAllControls();
      renderHeatmap(scope !== 'type');
    }

    const drawer = document.getElementById('data-drawer');
    document.getElementById('data-toggle').addEventListener('click', () => drawer.classList.toggle('open'));
    document.getElementById('data-close').addEventListener('click', () => drawer.classList.remove('open'));

    document.querySelectorAll('.mini-btns button').forEach(btn => {
      btn.addEventListener('click', () => setScopeSelection(btn.dataset.scope, btn.dataset.act));
    });

    document.getElementById('clear-filters').addEventListener('click', untickAll);
    document.getElementById('reset-filters').addEventListener('click', resetFilters);

    syncDynamicSelections();
    renderAllControls();
    renderLegend();
    renderHeatmap(true);
  </script>
</body>
</html>
"""

    html_content = (
        html_content
        .replace("__POINTS__", points_js)
        .replace("__STATES__", json.dumps(states))
        .replace("__DISTRICTS_BY_STATE__", json.dumps(districts_by_state))
        .replace("__YEARS__", json.dumps(years))
        .replace("__TYPES__", json.dumps(types))
        .replace("__COLORS__", json.dumps(colors))
    )

    output_file.write_text(html_content, encoding="utf-8")


def main() -> None:
    df = load_data()
    coords_df = load_coordinates()

    heat_data = build_heatmap_from_coordinates(df, coords_df)
    if not heat_data:
        raise SystemExit("No heat data generated. Check your CSV files.")

    write_html_map(heat_data, OUTPUT_FILE)
    print(f"✅ Heatmap generated successfully: {OUTPUT_FILE}")


if __name__ == "__main__":
    main()
